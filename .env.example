# ZeroTrust Health - Environment Variables Example
# Copy this file to .env and fill in your actual values.

# Nillion Keys for Party 1 (Patient)
NILLION_USERKEY_PATH_PARTY_1=/path/to/party1/user.key
NILLION_NODEKEY_PATH_PARTY_1=/path/to/party1/node.key

# Nillion Keys for Party 2 (Health Provider 1)
NILLION_USERKEY_PATH_PARTY_2=/path/to/party2/user.key
NILLION_NODEKEY_PATH_PARTY_2=/path/to/party2/node.key

# Nillion Keys for Party 3 (Health Provider 2)
NILLION_USERKEY_PATH_PARTY_3=/path/to/party3/user.key
NILLION_NODEKEY_PATH_PARTY_3=/path/to/party3/node.key

# Alternate Node Key for Party 1 (if used)
NILLION_NODEKEY_PATH_PARTY_4=/path/to/party1/node_alternate.key
